rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'aYYsXGKYRmObbUGYPP3lyheln9Q2';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── Restaurants — ทุกคนอ่านได้, Admin/เจ้าของร้านแก้ไขได้ ──────────────
    match /restaurants/{restaurantId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Menu Items — ทุกคนอ่านได้, Admin/เจ้าของร้านแก้ไขได้ ──────────────
    match /menu_items/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin()
                   || (isAuth() && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
                       && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid);
    }

    // ─── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin()
                    || (isAuth() && (
                          resource.data.customerId    == request.auth.uid
                          || resource.data.riderId    == request.auth.uid
                          || resource.data.riderUid   == request.auth.uid
                          || resource.data.merchantUid == request.auth.uid
                          || (resource.data.riderId == null
                              && resource.data.status == 'ready_to_pickup')
                       ));
      allow delete: if isAdmin();
    }

    // ─── Pending Requests — User สร้างได้, Admin จัดการได้ ──────────────────
    match /pending_requests/{reqId} {
      // list (collection query): เปิดให้ logged-in ทุกคน
      //   client ใช้ where('userId','==',uid) กรองเองอยู่แล้ว
      //   ถ้า rule ตรวจ resource.data ต่อ doc → Firestore reject query ทั้งหมด
      //   เพราะ doc ของ user อื่นจะ fail rule → subscription ตายเงียบ
      allow list:   if isAuth();
      // get (single doc): Admin หรือเจ้าของ doc เท่านั้น
      allow get:    if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── User Profiles — อ่าน/เขียนเฉพาะของตัวเอง, Admin อ่านทั้งหมด ────────
    match /users/{userId} {
      allow read:  if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    // ─── Wallets — อ่าน/เขียนเฉพาะของตัวเอง, Admin จัดการได้ ───────────────
    // All income credits go through Cloud Functions (Admin SDK, bypasses rules).
    // Client-side writes: owner deducts own balance (payment), Admin credits refunds.
    match /wallets/{userId} {
      allow read:  if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);

      // ── Wallet Entries subcollection ──────────────────────────────────────
      match /entries/{entryId} {
        allow read:   if isAdmin() || isOwner(userId);
        allow create: if isAdmin() || isOwner(userId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ─── System Config — ทุกคนอ่านได้, Admin เขียนได้ ───────────────────────
    match /system/{document} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Riders ──────────────────────────────────────────────────────────────
    match /riders/{riderId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Chats ───────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ─── Admin Notifications ─────────────────────────────────────────────────
    match /admin_notifs/{notifId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }

    // ─── Transaction Log (immutable audit log) ───────────────────────────────
    match /transactions/{txId} {
      allow read:   if isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}

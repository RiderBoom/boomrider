rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Global auth helpers ───────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'aYYsXGKYRmObbUGYPP3lyheln9Q2';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── Order field-level security helpers ───────────────────────────────────

    // Fields set at creation time — must never change after create.
    function orderCoreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['grandTotal', 'deliveryFee', 'customerId', 'restaurantId',
                       'items', 'createdAt', 'orderType', 'paymentMethod']);
    }

    // Routes update permission to the correct role handler.
    function authorizedOrderUpdate() {
      return orderCoreUnchanged() && (
          customerOrderUpdate()
          || merchantOrderUpdate()
          || riderOwnOrderUpdate()
          || riderAcceptingJob()
      );
    }

    // Customer: may only cancel a pending/confirmed order; cannot touch
    // financial or rider-assignment fields.
    function customerOrderUpdate() {
      return resource.data.customerId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['riderUid', 'riderId', 'merchantUid',
                       'grandTotal', 'deliveryFee'])
          && (request.resource.data.status == resource.data.status
              || (resource.data.status in ['pending', 'confirmed']
                  && request.resource.data.status == 'cancelled'));
    }

    // Merchant: may advance order status and write merchant metadata; cannot
    // touch financial totals, customer identity, or rider assignment.
    function merchantOrderUpdate() {
      return resource.data.merchantUid == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['riderUid', 'riderId', 'customerId',
                       'grandTotal', 'deliveryFee', 'items'])
          && (request.resource.data.status == resource.data.status
              || validMerchantStatusTransition());
    }

    function validMerchantStatusTransition() {
      let s = resource.data.status;
      let t = request.resource.data.status;
      return (s == 'pending'   && t in ['confirmed', 'cancelled'])
          || (s == 'confirmed' && t in ['preparing', 'ready_to_pickup', 'cancelled'])
          || (s == 'preparing' && t == 'ready_to_pickup');
    }

    // Rider: may update delivery progress on their own assigned order; cannot
    // touch financial fields or customer/merchant identity.
    function riderOwnOrderUpdate() {
      return (resource.data.riderUid == request.auth.uid
              || resource.data.riderId == request.auth.uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['customerId', 'merchantUid', 'restaurantId',
                       'grandTotal', 'deliveryFee', 'items'])
          && (request.resource.data.status == resource.data.status
              || validRiderStatusTransition());
    }

    function validRiderStatusTransition() {
      let s = resource.data.status;
      let t = request.resource.data.status;
      return (s == 'ready_to_pickup' && t == 'delivering')
          || (s == 'delivering'      && t == 'delivered');
    }

    // Rider: accepting an unassigned available job (sets riderUid / riderId);
    // cannot modify financial fields or customer/merchant identity.
    function riderAcceptingJob() {
      return resource.data.status == 'ready_to_pickup'
          && resource.data.get('riderUid', null) == null
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['customerId', 'merchantUid', 'restaurantId',
                       'grandTotal', 'deliveryFee', 'items']);
    }

    // ─── Restaurants — ทุกคนอ่านได้, Admin/เจ้าของร้านแก้ไขได้ ──────────────
    match /restaurants/{restaurantId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Menu Items — ทุกคนอ่านได้, Admin/เจ้าของร้านแก้ไขได้ ──────────────
    match /menu_items/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin()
                   || (isAuth() && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
                       && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid);
    }

    // ─── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth();

      // Create: caller must own the order (customerId = uid), initial status
      // must be 'pending', rider-assignment fields must not be pre-populated.
      allow create: if isAdmin()
                    || (isAuth()
                        && request.resource.data.customerId == request.auth.uid
                        && request.resource.data.status == 'pending'
                        && !('riderUid' in request.resource.data)
                        && !('riderId' in request.resource.data));

      allow update: if isAdmin() || authorizedOrderUpdate();
      allow delete: if isAdmin();
    }

    // ─── Pending Requests — User สร้างได้, Admin จัดการได้ ──────────────────
    match /pending_requests/{reqId} {
      allow list:   if isAuth();
      allow get:    if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── User Profiles — อ่าน/เขียนเฉพาะของตัวเอง, Admin อ่านทั้งหมด ────────
    match /users/{userId} {
      allow read:  if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    // ─── Wallets — อ่าน/เขียนเฉพาะของตัวเอง, Admin จัดการได้ ───────────────
    // All income credits go through Cloud Functions (Admin SDK, bypasses rules).
    // Client-side writes: owner deducts own balance (payment), Admin credits refunds.
    match /wallets/{userId} {
      allow read:  if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);

      // ── Wallet Entries subcollection ──────────────────────────────────────
      match /entries/{entryId} {
        allow read:   if isAdmin() || isOwner(userId);
        allow create: if isAdmin() || isOwner(userId);
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ─── System Config — ทุกคนอ่านได้, Admin เขียนได้ ───────────────────────
    match /system/{document} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Riders ──────────────────────────────────────────────────────────────
    match /riders/{riderId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Chats ───────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ─── Admin Notifications ─────────────────────────────────────────────────
    match /admin_notifs/{notifId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }

    // ─── Transaction Log (immutable audit log) ───────────────────────────────
    match /transactions/{txId} {
      allow read:   if isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Ratings — ลูกค้าสร้างได้ (1 doc/order), ทุกคนอ่านได้ ────────────────
    match /ratings/{orderId} {
      allow read:   if true;
      allow create: if isAuth();
      allow update: if isAdmin() || (isAuth() && resource.data.customerId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}

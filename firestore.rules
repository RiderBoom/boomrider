rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Global auth helpers ───────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'aYYsXGKYRmObbUGYPP3lyheln9Q2';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── Order field-level security helpers ───────────────────────────────────

    function orderCoreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['grandTotal', 'deliveryFee', 'customerId', 'restaurantId',
                       'items', 'createdAt', 'orderType', 'paymentMethod']);
    }

    function authorizedOrderUpdate() {
      return orderCoreUnchanged() && (
          customerOrderUpdate()
          || merchantOrderUpdate()
          || riderOwnOrderUpdate()
          || riderAcceptingJob()
      );
    }

    // Customer: cancel pending orders, confirm delivery (delivered → completed).
    function customerOrderUpdate() {
      return resource.data.customerId == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['riderUid', 'riderId', 'merchantUid',
                       'grandTotal', 'deliveryFee'])
          && (request.resource.data.status == resource.data.status
              || (resource.data.status in ['pending', 'confirmed']
                  && request.resource.data.status == 'cancelled')
              || (resource.data.status == 'delivered'
                  && request.resource.data.status == 'completed'));
    }

    // Merchant: advance status and write metadata; cannot touch financials or rider.
    function merchantOrderUpdate() {
      return resource.data.merchantUid == request.auth.uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['riderUid', 'riderId', 'customerId',
                       'grandTotal', 'deliveryFee', 'items'])
          && (request.resource.data.status == resource.data.status
              || validMerchantStatusTransition());
    }

    function validMerchantStatusTransition() {
      let s = resource.data.status;
      let t = request.resource.data.status;
      return (s == 'pending'   && t in ['preparing', 'ready_to_pickup', 'cancelled'])
          || (s == 'preparing' && t in ['ready_to_pickup', 'cancelled']);
    }

    // Rider: update delivery progress on their assigned order.
    function riderOwnOrderUpdate() {
      return (resource.data.riderUid == request.auth.uid
              || resource.data.riderId == request.auth.uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['customerId', 'merchantUid', 'restaurantId',
                       'grandTotal', 'deliveryFee', 'items'])
          && (request.resource.data.status == resource.data.status
              || validRiderStatusTransition());
    }

    // Fixed: all four delivery steps are now covered.
    function validRiderStatusTransition() {
      let s = resource.data.status;
      let t = request.resource.data.status;
      return (s == 'rider_accepted' && t == 'picking_up')
          || (s == 'picking_up'     && t == 'delivering')
          || (s == 'delivering'     && t == 'delivered');
    }

    // Rider accepting an unassigned job: must target rider_accepted status.
    function riderAcceptingJob() {
      return resource.data.status == 'ready_to_pickup'
          && request.resource.data.status == 'rider_accepted'
          && resource.data.get('riderUid', null) == null
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['customerId', 'merchantUid', 'restaurantId',
                       'grandTotal', 'deliveryFee', 'items']);
    }

    // ─── Restaurants ──────────────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Menu Items ───────────────────────────────────────────────────────────
    match /menu_items/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin()
                   || (isAuth() && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
                       && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid);
    }

    // ─── Orders ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth();

      // Food orders start at 'pending'; parcel orders start at 'ready_to_pickup'.
      allow create: if isAdmin()
                    || (isAuth()
                        && request.resource.data.customerId == request.auth.uid
                        && (request.resource.data.status == 'pending'
                            || (request.resource.data.status == 'ready_to_pickup'
                                && request.resource.data.get('type', '') == 'parcel'))
                        && !('riderUid' in request.resource.data)
                        && !('riderId' in request.resource.data));

      allow update: if isAdmin() || authorizedOrderUpdate();
      allow delete: if isAdmin();
    }

    // ─── Pending Requests ─────────────────────────────────────────────────────
    match /pending_requests/{reqId} {
      allow list:   if isAuth();
      allow get:    if isAdmin() || (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── User Profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    // ─── Wallets ──────────────────────────────────────────────────────────────
    // Self-credit attack mitigation:
    //   - Owner may only DEDUCT their own balance (payments).
    //   - Any authenticated user (e.g., merchant) may CREDIT another user's wallet
    //     (refunds on cancellation). Credits to self are blocked.
    //   - All income credits from Cloud Functions use Admin SDK (bypasses rules).
    match /wallets/{userId} {
      allow read:   if isAdmin() || isOwner(userId);
      allow create: if isAdmin() || isOwner(userId);
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && request.resource.data.balance <= resource.data.balance)
                    || (isAuth() && !isOwner(userId)
                        && request.resource.data.balance >= resource.data.balance);
      allow delete: if isAdmin();

      // Wallet entry history (immutable audit log per user).
      match /entries/{entryId} {
        allow read:   if isAdmin() || isOwner(userId);
        allow create: if isAuth();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ─── System Config ────────────────────────────────────────────────────────
    match /system/{document} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── Riders ───────────────────────────────────────────────────────────────
    match /riders/{riderId} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (isAuth() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── Rider Live Locations (GPS fan-out fix — separate from orders) ────────
    match /rider_locations/{riderUid} {
      allow read:   if isAuth();
      allow write:  if isAdmin() || isOwner(riderUid);
    }

    // ─── Chats ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ─── Admin Notifications ──────────────────────────────────────────────────
    match /admin_notifs/{notifId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }

    // ─── Transaction Log (immutable) ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read:   if isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Ratings ──────────────────────────────────────────────────────────────
    // Only the actual customer of that order may create a rating.
    match /ratings/{orderId} {
      allow read:   if true;
      allow create: if isAuth()
                    && request.resource.data.customerId == request.auth.uid
                    && exists(/databases/$(database)/documents/orders/$(orderId))
                    && get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid;
      allow update: if isAdmin() || (isAuth() && resource.data.customerId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
